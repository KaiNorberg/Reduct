(def fizzbuzz (lambda (limit)
    (def iter (lambda (n)
        (if {n >= limit}
            ""
            (iter (println! (++ n)             
                (cond
                    ({n % 15 == 0} "FizzBuzz")
                    ({n % 3 == 0} "Fizz")
                    ({n % 5 == 0} "Buzz")
                    (true n)
                )
            ))
        )
    ))

    (iter 0)
))

(fizzbuzz 10000)