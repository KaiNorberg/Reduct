(def sieve (lambda (limit)
    (def loop (lambda (nums acc)
        (if (empty? nums)
            (concat acc nums)
            (do
                (def p (first nums))
                (if {p * p > limit}
                    (concat acc nums)
                    (recur (filter (rest nums) (lambda (x) {x % p != 0})) (append acc p))
                )
            )
        )
    ))
    (loop (range 2 {limit + 1}) ())
))

(sieve 10000)