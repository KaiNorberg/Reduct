(do
    (assert! (== (try (lambda () (+ 1 2)) (lambda (err) "fail")) 3) "try should return result of callable if no error")
    (assert! (== (try (lambda () (throw "error message")) (lambda (err) err)) "error message") "try should catch throw and return error message to handler")
    
    (def result (try 
        (lambda () (assert! false "assert!ion failed"))
        (lambda (msg) (concat "caught: " msg))
    ))
    (assert! (== result "caught: assert!ion failed") "try should catch failed assert!")
)
