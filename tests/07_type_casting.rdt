(-> (world!)
    (assert! (== (number "42") 42) "number should convert string to number")
    (assert! (== (number 3.14) 3.14) "number should pass through number types")
    (assert! (== (number "0x10") 16) "number should convert hex string to number")
    (assert! (== (number "0b1010") 10) "number should convert binary string to number")
    (assert! (== (number "3.14") 3.14) "number should convert float string to number")
    (assert! (== (number 42) 42) "number should pass through integer types")
    (assert! (== (number "1e3") 1000) "number should convert scientific notation to number")
)
